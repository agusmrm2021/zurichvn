{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static HTML Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-c", "import os,http.server,socketserver; port=int(os.environ['PORT']); httpd=socketserver.TCPServer(('',port),http.server.SimpleHTTPRequestHandler); httpd.serve_forever()"],
      "autoPort": true
    }
  ]
}
